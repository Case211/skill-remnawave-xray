            "xmux": {
              "cMaxLifetimeMs": 0,
              "cMaxReuseTimes": 0,
              "maxConcurrency": "16-32",
              "maxConnections": 0
            },
            "xPaddingKey": "_dc",
            "xPaddingHeader": "X-Cache",
            "xPaddingMethod": "tokenish",
            "uplinkHTTPMethod": "GET",
            "xPaddingObfsMode": true,
            "xPaddingPlacement": "queryInHeader"
          }
        }
      }
    },
    {
      "tag": "RU-XHTTP-CDN-3",
      "port": 5449,
      "listen": "127.0.0.1",
      "protocol": "vless",
      "settings": {
        "clients": [],
        "decryption": "none"
      },
      "sniffing": {
        "enabled": false
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "none",
        "xhttpSettings": {
          "host": "<CDN_FRONT_HOST>",
          "mode": "packet-up",
