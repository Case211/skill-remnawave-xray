            "xmux": {
              "cMaxLifetimeMs": 0,
              "cMaxReuseTimes": 0,
              "maxConcurrency": "16-32",
              "maxConnections": 0
            },
            "xPaddingKey": "_dc",
            "xPaddingHeader": "X-Cache",
            "xPaddingMethod": "tokenish",
            "uplinkHTTPMethod": "GET",
            "xPaddingObfsMode": true,
            "xPaddingPlacement": "queryInHeader"
          }
        }
      }
    }
  ],
  "outbounds": [
    {
      "tag": "ToGermany",
      "protocol": "vless",
      "settings": {
        "id": "<CLIENT_UUID>",
        "flow": "xtls-rprx-vision",
        "port": 443,
        "address": "<DE_NODE_DOMAIN>",
        "encryption": "none"
      },
      "streamSettings": {
        "network": "raw",
        "security": "reality",
        "realitySettings": {
          "password": "<REALITY_PUBLIC_KEY>",
          "serverName": "<DE_NODE_DOMAIN>",
          "fingerprint": "firefox"
        }
      }
    },
    {
      "tag": "DIRECT",
      "protocol": "freedom"
    },
    {
      "tag": "BLOCK",
      "protocol": "blackhole"
    }
  ],
  "routing": {
    "rules": [
      {
        "ip": [
          "geoip:private"
        ],
        "outboundTag": "BLOCK"
      },
      {
        "domain": [
          "geosite:private"
        ],
        "outboundTag": "BLOCK"
      },
      {
        "protocol": [
          "bittorrent"
        ],
        "outboundTag": "BLOCK"
      },
      {
        "inboundTag": [
          "RU-WS-CDN",
          "RU-WS-CDN-2",
          "RU-WS-CDN-3",
          "RU-WS-CDN-4",
          "RU-XHTTP-CDN-1",
          "RU-XHTTP-CDN-2",
          "RU-XHTTP-CDN-3"
        ],
        "outboundTag": "ToGermany"
      }
    ]
  }
}
